{
  "name": "spec42",
  "displayName": "SysML v2 Editor",
  "publisher": "Elan8",
  "icon": "logo/logo.png",
  "description": "Language support for SysML v2 including syntax validation, navigation and diagnostics.",
  "version": "0.10.0",
  "license": "MIT",
  "keywords": [
    "sysml",
    "sysml-v2",
    "mbse",
    "systems engineering",
    "model based systems engineering"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/elan8/spec42.git"
  },
  "homepage": "https://github.com/elan8/spec42#readme",
  "bugs": {
    "url": "https://github.com/elan8/spec42/issues"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Linters"
  ],
  "activationEvents": [
    "workspaceContains:**/*.sysml",
    "workspaceContains:**/*.kerml",
    "onWebviewPanel:sysmlVisualizer"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "sysml",
        "aliases": [
          "SysML",
          "SysML v2"
        ],
        "extensions": [
          ".sysml"
        ],
        "configuration": "./language-configuration.json"
      },
      {
        "id": "kerml",
        "aliases": [
          "KerML",
          "Kernel Modeling Language"
        ],
        "extensions": [
          ".kerml"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "snippets": [
      {
        "language": "sysml",
        "path": "./snippets/sysml.json"
      },
      {
        "language": "kerml",
        "path": "./snippets/sysml.json"
      }
    ],
    "commands": [
      {
        "command": "sysml.formatDocument",
        "title": "Format SysML Document",
        "category": "SysML"
      },
      {
        "command": "sysml.validateModel",
        "title": "Validate SysML Model",
        "category": "SysML"
      },
      {
        "command": "sysml.restartServer",
        "title": "Restart SysML Language Server",
        "category": "SysML"
      },
      {
        "command": "sysml.showModelExplorer",
        "title": "Show SysML Model Explorer",
        "category": "SysML"
      },
      {
        "command": "sysml.refreshModelTree",
        "title": "Refresh SysML Model Explorer",
        "icon": "$(refresh)",
        "category": "SysML"
      },
      {
        "command": "sysml.library.refresh",
        "title": "Refresh Library View",
        "icon": "$(refresh)",
        "category": "Spec42"
      },
      {
        "command": "sysml.library.installStdLib",
        "title": "Library: Install or Update Standard Library",
        "icon": "$(cloud-download)",
        "category": "Spec42"
      },
      {
        "command": "sysml.library.managePaths",
        "title": "Library: Manage Custom Libraries",
        "icon": "$(folder-library)",
        "category": "Spec42"
      },
      {
        "command": "sysml.library.search",
        "title": "Library: Search Libraries",
        "icon": "$(search)",
        "category": "Spec42"
      },
      {
        "command": "sysml.library.showStdLibStatus",
        "title": "Library: Show Standard Library Status",
        "icon": "$(info)",
        "category": "Spec42"
      },
      {
        "command": "sysml.showVisualizer",
        "title": "Show SysML Visualizer",
        "icon": "$(open-preview)",
        "category": "SysML"
      },
      {
        "command": "sysml.clearCache",
        "title": "Clear SysML Parse Cache",
        "category": "SysML"
      },
      {
        "command": "sysml.visualizePackage",
        "title": "Visualize Package",
        "category": "SysML"
      },
      {
        "command": "sysml.switchToByFile",
        "title": "Switch to By File",
        "icon": "$(file)",
        "category": "SysML"
      },
      {
        "command": "sysml.switchToSemanticModel",
        "title": "Switch to Semantic Model",
        "icon": "$(symbol-class)",
        "category": "SysML"
      },
      {
        "command": "sysml.toggleWorkspaceViewMode",
        "title": "Toggle Model View Mode",
        "category": "SysML"
      },
      {
        "command": "sysml.visualizeFolder",
        "title": "Visualize Folder (SysML)",
        "category": "SysML"
      },
      {
        "command": "sysml.showOutput",
        "title": "Show SysML Output (Logs)",
        "category": "SysML"
      },
      {
        "command": "sysml.changeVisualizerView",
        "title": "Change Visualizer View",
        "category": "SysML"
      },
      {
        "command": "sysml.exportVisualization",
        "title": "Export Visualization (PNG/SVG)",
        "category": "SysML"
      },
      {
        "command": "sysml.refreshVisualization",
        "title": "Refresh Visualization",
        "category": "SysML"
      },
      {
        "command": "sysml.visualizeFolderWithView",
        "title": "Visualize Folder with View...",
        "category": "SysML"
      },
      {
        "command": "sysml.debugSemanticTokenAtCursor",
        "title": "Debug: Semantic Token at Cursor",
        "category": "SysML"
      },
      {
        "command": "sysml.debugDumpGraphForGeneralView",
        "title": "Debug: Dump Graph for General View",
        "category": "SysML"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "sysml.switchToByFile",
          "when": "view == sysmlModelExplorer && sysml.hasWorkspace && sysml.workspaceViewMode != 'byFile'",
          "group": "navigation"
        },
        {
          "command": "sysml.switchToSemanticModel",
          "when": "view == sysmlModelExplorer && sysml.hasWorkspace && sysml.workspaceViewMode != 'bySemantic'",
          "group": "navigation"
        },
        {
          "command": "sysml.refreshModelTree",
          "when": "view == sysmlModelExplorer",
          "group": "navigation"
        },
        {
          "command": "sysml.library.refresh",
          "when": "view == spec42Library",
          "group": "navigation"
        }
      ],
      "editor/title": [
        {
          "command": "sysml.showVisualizer",
          "when": "resourceLangId == sysml || resourceLangId == kerml",
          "group": "navigation"
        }
      ],
      "explorer/context": [
        {
          "command": "sysml.visualizeFolder",
          "when": "explorerResourceIsFolder",
          "group": "navigation"
        },
        {
          "command": "sysml.visualizeFolderWithView",
          "when": "explorerResourceIsFolder",
          "group": "navigation"
        },
        {
          "command": "sysml.visualizeFolder",
          "when": "resourceExtname == .sysml || resourceExtname == .kerml",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "sysml.visualizePackage",
          "when": "view == sysmlModelExplorer && viewItem == sysmlPackage"
        }
      ],
      "commandPalette": [
        {
          "command": "sysml.formatDocument",
          "when": "resourceLangId == sysml || resourceLangId == kerml"
        },
        {
          "command": "sysml.validateModel",
          "when": "resourceLangId == sysml || resourceLangId == kerml"
        },
        {
          "command": "sysml.restartServer"
        },
        {
          "command": "sysml.showModelExplorer"
        },
        {
          "command": "sysml.refreshModelTree"
        },
        {
          "command": "sysml.showVisualizer"
        },
        {
          "command": "sysml.clearCache"
        },
        {
          "command": "sysml.showOutput"
        },
        {
          "command": "sysml.changeVisualizerView"
        },
        {
          "command": "sysml.exportVisualization"
        },
        {
          "command": "sysml.refreshVisualization"
        },
        {
          "command": "sysml.library.refresh"
        },
        {
          "command": "sysml.library.installStdLib"
        },
        {
          "command": "sysml.library.managePaths"
        },
        {
          "command": "sysml.library.search"
        },
        {
          "command": "sysml.library.showStdLibStatus"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "spec42",
          "title": "Spec42",
          "icon": "design/logo.svg"
        }
      ]
    },
    "views": {
      "spec42": [
        {
          "id": "sysmlModelExplorer",
          "name": "Model Explorer"
        },
        {
          "id": "spec42Library",
          "name": "Library",
          "type": "webview",
          "contextualTitle": "Spec42 Library"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "spec42Library",
        "contents": "Spec42 manages a pinned standard library after installation.\\n\\n- Run [Install or Update Standard Library](command:sysml.library.installStdLib)\\n- Run [Manage Custom Libraries](command:sysml.library.managePaths)\\n- Run [Show Standard Library Status](command:sysml.library.showStdLibStatus)"
      },
      {
        "view": "sysmlModelExplorer",
        "contents": "No SysML model loaded.\\n\\n- Open a `.sysml` or `.kerml` file\\n- Or run **SysML: Show SysML Model Explorer**"
      }
    ],
    "configuration": {
      "title": "Spec42",
      "properties": {
        "spec42.serverPath": {
          "type": "string",
          "default": "spec42",
          "description": "Path to the Spec42 server binary (or 'spec42' if on PATH)."
        },
        "spec42.libraryPaths": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Custom paths to additional SysML library roots. Files under these paths are indexed for hover, go-to-definition, and completion."
        },
        "spec42.standardLibrary.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable managed standard library support from the configured SysML v2 release source."
        },
        "spec42.standardLibrary.version": {
          "type": "string",
          "default": "2026-02",
          "description": "Pinned SysML v2 release tag to install for the managed standard library."
        },
        "spec42.standardLibrary.repo": {
          "type": "string",
          "default": "Systems-Modeling/SysML-v2-Release",
          "description": "GitHub repository (owner/name) used for managed standard library downloads."
        },
        "spec42.standardLibrary.contentPath": {
          "type": "string",
          "default": "sysml.library",
          "description": "Repository subfolder to install as the managed standard library."
        },
        "spec42.statusBar.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Show a SysML status bar item with error/warning counts for the active SysML/KerML file."
        },
        "spec42.workspace.maxFilesPerPattern": {
          "type": "number",
          "default": 500,
          "minimum": 50,
          "description": "Maximum number of .sysml or .kerml files to discover per workspace folder and file type during workspace indexing. Increase for larger repositories at the cost of slower loading."
        },
        "spec42.debug": {
          "type": "boolean",
          "default": false,
          "description": "Enable debug logging to the SysML output channel (View → Output → SysML)."
        },
        "spec42.logging.verbose": {
          "type": "boolean",
          "default": false,
          "description": "Enable verbose runtime logging for troubleshooting in production installs (visualizer/webview/message flow)."
        },
        "spec42.debug.dumpSemanticTokens": {
          "type": "boolean",
          "default": false,
          "description": "When true, dump semantic tokens received from the server to semantic_tokens_frontend_dump.txt in the workspace root (for debugging highlighting)."
        },
        "spec42.visualization.defaultView": {
          "type": "string",
          "enum": [
            "general-view"
          ],
          "default": "general-view",
          "description": "Default view when opening the SysML Model Visualizer (SysML v2 frameless-view types)."
        },
        "spec42.visualization.enableExperimentalViews": {
          "type": "boolean",
          "default": false,
          "description": "Enable experimental diagram views in the visualizer UI, such as action flow, state transition, and sequence views."
        },
        "spec42.visualization.exportScale": {
          "type": "number",
          "default": 2,
          "minimum": 1,
          "maximum": 4,
          "description": "Scale factor for PNG/SVG export of the visualization."
        },
        "spec42.visualization.generalViewPalette": {
          "type": "string",
          "enum": [
            "distinct",
            "classic"
          ],
          "default": "distinct",
          "description": "Color palette for General View: 'distinct' (semantic SysML pillar colors) or 'classic' (VS Code default syntax colors)."
        }
      }
    },
    "configurationDefaults": {
      "[sysml]": {
        "editor.semanticHighlighting.enabled": true,
        "editor.guides.indentation": false,
        "editor.guides.bracketPairs": false,
        "editor.bracketPairColorization.enabled": false,
        "breadcrumbs.enabled": true,
        "breadcrumbs.showModules": true,
        "breadcrumbs.showNamespaces": true
      },
      "[kerml]": {
        "editor.semanticHighlighting.enabled": true,
        "editor.guides.indentation": false,
        "editor.guides.bracketPairs": false,
        "editor.bracketPairColorization.enabled": false,
        "breadcrumbs.enabled": true,
        "breadcrumbs.showModules": true,
        "breadcrumbs.showNamespaces": true
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build:webview-assets && npm run build:webview && npm run compile",
    "build:webview-assets": "node scripts/copy-webview-assets.js",
    "build:webview": "node scripts/build-webview.js",
    "verify:package-layout": "node scripts/verify-package-layout.js",
    "extract-styles": "node scripts/extract-styles.js",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "test": "vscode-test",
    "test:interconnection": "vscode-test --config .vscode-test.interconnection.mjs",
    "test:interconnection-drone": "vscode-test --config .vscode-test.interconnection-drone.mjs",
    "test:multi-file": "vscode-test --config .vscode-test.multi-file.mjs",
    "test:workspace-smoke": "vscode-test --config .vscode-test.workspace-smoke.mjs",
    "test:sysml-examples": "vscode-test --config .vscode-test.sysml-examples.mjs",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/mocha": "^10.0.0",
    "@types/node": "^22.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/codicons": "0.0.44",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.4.1",
    "@vscode/vsce": "^3.2.2",
    "esbuild": "^0.24.0",
    "typescript": "~5.6.0"
  },
  "dependencies": {
    "adm-zip": "^0.5.16",
    "d3": "^7.9.0",
    "elkjs": "^0.8.2",
    "vscode-languageclient": "^9.0.0",
    "vscode-languageserver-protocol": "^3.17.0"
  }
}
