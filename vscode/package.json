{
  "name": "spec42",
  "displayName": "SysML v2 Editor",
  "publisher": "Elan8",
  "icon": "logo/logo.png",
  "description": "SysML v2 and KerML editor with live validation, navigation, Model Explorer, diagram views, CLI checks and GitHub Action support.",
  "version": "0.36.0",
  "license": "MIT",
  "keywords": [
    "sysml",
    "sysml-v2",
    "kerml",
    "mbse",
    "systems engineering",
    "model based systems engineering",
    "model validation",
    "visualization",
    "lsp"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/elan8/spec42.git"
  },
  "homepage": "https://github.com/elan8/spec42#readme",
  "bugs": {
    "url": "https://github.com/elan8/spec42/issues"
  },
  "engines": {
    "vscode": "^1.99.0"
  },
  "categories": [
    "Programming Languages",
    "Linters",
    "Visualization"
  ],
  "activationEvents": [
    "workspaceContains:**/*.sysml",
    "workspaceContains:**/*.kerml"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "sysml",
        "aliases": [
          "SysML",
          "SysML v2"
        ],
        "extensions": [
          ".sysml"
        ],
        "configuration": "./language-configuration.json"
      },
      {
        "id": "kerml",
        "aliases": [
          "KerML",
          "Kernel Modeling Language"
        ],
        "extensions": [
          ".kerml"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "semanticTokenScopes": [
      {
        "language": "sysml",
        "scopes": {
          "keyword": [
            "keyword"
          ],
          "string": [
            "string"
          ],
          "number": [
            "number"
          ],
          "comment": [
            "comment"
          ],
          "operator": [
            "keyword.operator"
          ],
          "variable": [
            "variable"
          ],
          "type": [
            "type"
          ],
          "namespace": [
            "namespace"
          ],
          "class": [
            "type"
          ],
          "interface": [
            "interface"
          ],
          "property": [
            "variable.member"
          ],
          "function": [
            "function"
          ]
        }
      },
      {
        "language": "kerml",
        "scopes": {
          "keyword": [
            "keyword"
          ],
          "string": [
            "string"
          ],
          "number": [
            "number"
          ],
          "comment": [
            "comment"
          ],
          "operator": [
            "keyword.operator"
          ],
          "variable": [
            "variable"
          ],
          "type": [
            "type"
          ],
          "namespace": [
            "namespace"
          ],
          "class": [
            "type"
          ],
          "interface": [
            "interface"
          ],
          "property": [
            "variable.member"
          ],
          "function": [
            "function"
          ]
        }
      }
    ],
    "snippets": [
      {
        "language": "sysml",
        "path": "./snippets/sysml.json"
      },
      {
        "language": "kerml",
        "path": "./snippets/sysml.json"
      }
    ],
    "commands": [
      {
        "command": "sysml.formatDocument",
        "title": "Format SysML Document",
        "category": "SysML"
      },
      {
        "command": "sysml.validateModel",
        "title": "Validate SysML Model",
        "category": "SysML"
      },
      {
        "command": "sysml.restartServer",
        "title": "Restart SysML Language Server",
        "category": "SysML"
      },
      {
        "command": "sysml.showModelExplorer",
        "title": "Show SysML Model Explorer",
        "category": "SysML"
      },
      {
        "command": "sysml.refreshModelTree",
        "title": "Refresh SysML Model Explorer",
        "icon": "$(refresh)",
        "category": "SysML"
      },
      {
        "command": "spec42.examples.refresh",
        "title": "Refresh Examples View",
        "icon": "$(refresh)",
        "category": "Spec42"
      },
      {
        "command": "spec42.examples.openWorkspace",
        "title": "Examples: Open Workspace",
        "icon": "$(folder-opened)",
        "category": "Spec42"
      },
      {
        "command": "spec42.examples.openRecommended",
        "title": "Examples: Open Recommended Example",
        "icon": "$(star-full)",
        "category": "Spec42"
      },
      {
        "command": "spec42.help.openReference",
        "title": "Help: SysML v2 Quick Reference",
        "icon": "$(book)",
        "category": "Spec42"
      },
      {
        "command": "spec42.status.showActions",
        "title": "Status: Show Spec42 Actions",
        "icon": "$(list-selection)",
        "category": "Spec42"
      },
      {
        "command": "sysml.library.refresh",
        "title": "Refresh Library View",
        "icon": "$(refresh)",
        "category": "Spec42"
      },
      {
        "command": "sysml.library.managePaths",
        "title": "Library: Manage Custom Libraries",
        "icon": "$(folder-library)",
        "category": "Spec42"
      },
      {
        "command": "sysml.library.search",
        "title": "Library: Search Libraries",
        "icon": "$(search)",
        "category": "Spec42"
      },
      {
        "command": "sysml.library.showStdLibStatus",
        "title": "Library: Standard Library Information",
        "icon": "$(info)",
        "category": "Spec42"
      },
      {
        "command": "sysml.library.showDomainLibrariesStatus",
        "title": "Library: Domain Libraries Information",
        "icon": "$(info)",
        "category": "Spec42"
      },
      {
        "command": "sysml.sysand.showStatus",
        "title": "Sysand: Show Status",
        "icon": "$(package)",
        "category": "Spec42"
      },
      {
        "command": "sysml.sysand.refreshDependencies",
        "title": "Sysand: Refresh Dependencies",
        "icon": "$(sync)",
        "category": "Spec42"
      },
      {
        "command": "sysml.showVisualizer",
        "title": "Open SysML Visualizer",
        "icon": {
          "light": "media/icons/sysml-visualizer-logo.light.svg",
          "dark": "media/icons/sysml-visualizer-logo.dark.svg"
        },
        "category": "SysML"
      },
      {
        "command": "sysml.showVisualizerActive",
        "title": "SysML Visualizer (Open)",
        "icon": {
          "light": "media/icons/sysml-visualizer-logo-active.light.svg",
          "dark": "media/icons/sysml-visualizer-logo-active.dark.svg"
        },
        "category": "SysML"
      },
      {
        "command": "sysml.showTypeHierarchy",
        "title": "Show Type Hierarchy",
        "icon": "$(type-hierarchy)",
        "category": "SysML"
      },
      {
        "command": "sysml.showCallHierarchy",
        "title": "Show Call Hierarchy",
        "icon": "$(call-hierarchy)",
        "category": "SysML"
      },
      {
        "command": "sysml.clearCache",
        "title": "Clear SysML Parse Cache",
        "category": "SysML"
      },
      {
        "command": "sysml.visualizePackage",
        "title": "Visualize Package",
        "category": "SysML"
      },
      {
        "command": "sysml.openLocation",
        "title": "Open Source",
        "icon": "$(go-to-file)",
        "category": "SysML"
      },
      {
        "command": "sysml.copyQualifiedName",
        "title": "Copy Qualified Name",
        "icon": "$(copy)",
        "category": "SysML"
      },
      {
        "command": "sysml.switchToByFile",
        "title": "Switch to By File",
        "icon": "$(file)",
        "category": "SysML"
      },
      {
        "command": "sysml.switchToSemanticModel",
        "title": "Switch to Semantic Model",
        "icon": "$(symbol-class)",
        "category": "SysML"
      },
      {
        "command": "sysml.toggleWorkspaceViewMode",
        "title": "Toggle Model View Mode",
        "category": "SysML"
      },
      {
        "command": "sysml.visualizeFolder",
        "title": "Visualize Folder (SysML)",
        "category": "SysML"
      },
      {
        "command": "sysml.showOutput",
        "title": "Show SysML Output (Logs)",
        "category": "SysML"
      },
      {
        "command": "sysml.changeVisualizerView",
        "title": "Change Visualizer View",
        "category": "SysML"
      },
      {
        "command": "sysml.exportVisualization",
        "title": "Export Visualization (PNG/SVG)",
        "category": "SysML"
      },
      {
        "command": "sysml.refreshVisualization",
        "title": "Refresh Visualization",
        "category": "SysML"
      },
      {
        "command": "sysml.visualizeFolderWithView",
        "title": "Visualize Folder with View...",
        "category": "SysML"
      },
      {
        "command": "sysml.debugDumpGraphForGeneralView",
        "title": "Debug: Dump Graph for General View",
        "category": "SysML"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "sysml.switchToByFile",
          "when": "view == sysmlModelExplorer && sysml.hasWorkspace && sysml.workspaceViewMode != 'byFile'",
          "group": "navigation"
        },
        {
          "command": "sysml.switchToSemanticModel",
          "when": "view == sysmlModelExplorer && sysml.hasWorkspace && sysml.workspaceViewMode != 'bySemantic'",
          "group": "navigation"
        },
        {
          "command": "sysml.refreshModelTree",
          "when": "view == sysmlModelExplorer",
          "group": "navigation"
        },
        {
          "command": "sysml.library.refresh",
          "when": "view == spec42Library",
          "group": "navigation"
        },
        {
          "command": "spec42.examples.refresh",
          "when": "view == spec42Examples",
          "group": "navigation"
        }
      ],
      "explorer/context": [
        {
          "command": "sysml.visualizeFolder",
          "when": "explorerResourceIsFolder",
          "group": "navigation"
        },
        {
          "command": "sysml.visualizeFolderWithView",
          "when": "explorerResourceIsFolder",
          "group": "navigation"
        },
        {
          "command": "sysml.visualizeFolder",
          "when": "resourceExtname == .sysml || resourceExtname == .kerml",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "spec42.examples.openWorkspace",
          "when": "view == spec42Examples && (viewItem == spec42ExampleFolder || viewItem == spec42ExampleFolderRecommended)",
          "group": "navigation@1"
        },
        {
          "command": "sysml.openLocation",
          "when": "view == sysmlModelExplorer && (viewItem == sysmlElement || viewItem == sysmlPackage)",
          "group": "navigation@1"
        },
        {
          "command": "sysml.copyQualifiedName",
          "when": "view == sysmlModelExplorer && (viewItem == sysmlElement || viewItem == sysmlPackage)",
          "group": "inline@2"
        },
        {
          "command": "sysml.visualizePackage",
          "when": "view == sysmlModelExplorer && viewItem == sysmlPackage",
          "group": "navigation@3"
        }
      ],
      "editor/title": [
        {
          "command": "sysml.showVisualizer",
          "when": "(resourceLangId == sysml || resourceLangId == kerml) && !sysml.visualizerOpen",
          "group": "navigation"
        },
        {
          "command": "sysml.showVisualizerActive",
          "when": "(resourceLangId == sysml || resourceLangId == kerml) && sysml.visualizerOpen",
          "group": "navigation"
        }
      ],
      "commandPalette": [
        {
          "command": "sysml.formatDocument",
          "when": "resourceLangId == sysml || resourceLangId == kerml"
        },
        {
          "command": "sysml.validateModel",
          "when": "resourceLangId == sysml || resourceLangId == kerml"
        },
        {
          "command": "sysml.restartServer"
        },
        {
          "command": "sysml.showModelExplorer"
        },
        {
          "command": "sysml.refreshModelTree"
        },
        {
          "command": "sysml.showVisualizer"
        },
        {
          "command": "sysml.showVisualizerActive",
          "when": "false"
        },
        {
          "command": "sysml.showTypeHierarchy",
          "when": "resourceLangId == sysml || resourceLangId == kerml"
        },
        {
          "command": "sysml.showCallHierarchy",
          "when": "resourceLangId == sysml || resourceLangId == kerml"
        },
        {
          "command": "sysml.clearCache"
        },
        {
          "command": "sysml.showOutput"
        },
        {
          "command": "spec42.examples.openRecommended"
        },
        {
          "command": "sysml.changeVisualizerView"
        },
        {
          "command": "sysml.exportVisualization"
        },
        {
          "command": "sysml.refreshVisualization"
        },
        {
          "command": "sysml.library.refresh"
        },
        {
          "command": "sysml.library.managePaths"
        },
        {
          "command": "sysml.library.search"
        },
        {
          "command": "sysml.library.showStdLibStatus"
        },
        {
          "command": "sysml.library.showDomainLibrariesStatus"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "spec42",
          "title": "Spec42",
          "icon": "design/logo.svg"
        }
      ],
      "secondarySidebar": [
        {
          "id": "sysmlVisualizerContainer",
          "title": "SysML Visualizer",
          "icon": "design/logo.svg"
        }
      ]
    },
    "views": {
      "spec42": [
        {
          "id": "sysmlModelExplorer",
          "name": "Model Explorer"
        },
        {
          "id": "spec42Help",
          "name": "Help"
        },
        {
          "id": "spec42Examples",
          "name": "Examples"
        },
        {
          "id": "spec42Library",
          "name": "Library",
          "type": "webview",
          "contextualTitle": "Spec42 Library"
        }
      ],
      "sysmlVisualizerContainer": [
        {
          "type": "webview",
          "id": "sysmlVisualizerView",
          "name": "SysML Visualizer"
        }
      ]
    },
    "languageModelTools": [
      {
        "name": "spec42_check",
        "toolReferenceName": "spec42Check",
        "displayName": "Spec42 check",
        "modelDescription": "Run the same validation pipeline as `spec42 check`. Returns error and warning counts plus diagnostic codes. Use when validating SysML v2 or KerML models before edits or CI. Prefer spec42_model_summary for large semantic graphs.",
        "userDescription": "Validate SysML/KerML with Spec42 (same as spec42 check).",
        "canBeReferencedInPrompt": true,
        "icon": "$(checklist)",
        "when": "resourceExtname == .sysml || resourceExtname == .kerml || workspaceFolderCount > 0",
        "inputSchema": {
          "type": "object",
          "properties": {
            "path": {
              "type": "string",
              "description": "Absolute path to a .sysml/.kerml file or directory. Defaults to the active editor file or workspace folder."
            },
            "workspace_root": {
              "type": "string",
              "description": "Optional workspace root when validating a single file in a multi-file project."
            }
          }
        }
      },
      {
        "name": "spec42_doctor",
        "toolReferenceName": "spec42Doctor",
        "displayName": "Spec42 doctor",
        "modelDescription": "Report Spec42 environment: standard library, config/data dirs, library paths, and Sysand detection (same as `spec42 doctor`). Run before blaming unresolved imports on model text.",
        "userDescription": "Check Spec42 environment and library setup.",
        "canBeReferencedInPrompt": true,
        "icon": "$(heart)",
        "when": "workspaceFolderCount > 0",
        "inputSchema": {
          "type": "object",
          "properties": {}
        }
      },
      {
        "name": "spec42_model_summary",
        "toolReferenceName": "spec42ModelSummary",
        "displayName": "Spec42 model summary",
        "modelDescription": "Validate the path and return a capped semantic graph: nodes (qualified names, kinds) and relationships filtered to typing, connection, and reference. Use max_nodes to limit payload size.",
        "userDescription": "Compact semantic graph summary for a SysML model.",
        "canBeReferencedInPrompt": true,
        "icon": "$(type-hierarchy)",
        "when": "resourceExtname == .sysml || resourceExtname == .kerml || workspaceFolderCount > 0",
        "inputSchema": {
          "type": "object",
          "properties": {
            "path": {
              "type": "string",
              "description": "Absolute path to a .sysml/.kerml file or directory."
            },
            "workspace_root": {
              "type": "string",
              "description": "Optional workspace root."
            },
            "max_nodes": {
              "type": "number",
              "description": "Maximum semantic nodes to return (default 500)."
            }
          }
        }
      },
      {
        "name": "spec42_explain_diagnostic",
        "toolReferenceName": "spec42ExplainDiagnostic",
        "displayName": "Spec42 explain diagnostic",
        "modelDescription": "Catalog entry for a Spec42 diagnostic code (severity, meaning, typical fix). Optionally pass path and line to list matching instances from a check run.",
        "userDescription": "Explain a Spec42 diagnostic code and list instances.",
        "canBeReferencedInPrompt": true,
        "icon": "$(question)",
        "when": "resourceExtname == .sysml || resourceExtname == .kerml || workspaceFolderCount > 0",
        "inputSchema": {
          "type": "object",
          "properties": {
            "code": {
              "type": "string",
              "description": "Diagnostic code (for example unresolved_type_reference)."
            },
            "path": {
              "type": "string",
              "description": "Optional file or directory to list matching diagnostics."
            },
            "workspace_root": {
              "type": "string",
              "description": "Optional workspace root when path is set."
            },
            "line": {
              "type": "number",
              "description": "Optional 0-based line number to filter instances."
            }
          },
          "required": [
            "code"
          ]
        }
      }
    ],
    "viewsWelcome": [
      {
        "view": "spec42Library",
        "contents": "The SysML standard library and Elan8 domain libraries are bundled with the Spec42 language server.\\n\\n- Run [Manage Custom Libraries](command:sysml.library.managePaths)\\n- Run [Standard Library Information](command:sysml.library.showStdLibStatus)\\n- Run [Domain Libraries Information](command:sysml.library.showDomainLibrariesStatus)"
      },
      {
        "view": "sysmlModelExplorer",
        "contents": "No SysML model loaded.\\n\\n- Open a `.sysml` or `.kerml` file\\n- Run [Open Recommended Example](command:spec42.examples.openRecommended)\\n- Or use the **Examples** view in the Spec42 sidebar"
      }
    ],
    "configuration": {
      "title": "Spec42",
      "properties": {
        "spec42.serverPath": {
          "type": "string",
          "default": "spec42",
          "description": "Path to the Spec42 server binary (or 'spec42' if on PATH)."
        },
        "spec42.libraryPaths": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Custom paths to additional SysML library roots. Files under these paths are indexed for hover, go-to-definition, and completion."
        },
        "spec42.statusBar.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Show a SysML status bar item with error/warning counts for the active SysML/KerML file."
        },
        "spec42.performanceLogging.enabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable structured performance and startup logging for troubleshooting. Leave this off during normal use."
        },
        "spec42.workspace.maxFilesPerPattern": {
          "type": "number",
          "default": 500,
          "minimum": 50,
          "description": "Maximum number of .sysml or .kerml files to discover per workspace folder and file type during workspace indexing. Increase for larger repositories at the cost of slower loading."
        },
        "spec42.debug": {
          "type": "boolean",
          "default": false,
          "description": "Enable debug logging to the SysML output channel (View \u2192 Output \u2192 SysML)."
        },
        "spec42.logging.verbose": {
          "type": "boolean",
          "default": false,
          "description": "Enable verbose runtime logging for troubleshooting in production installs (visualizer/webview/message flow)."
        },
        "spec42.visualization.exportScale": {
          "type": "number",
          "default": 2,
          "minimum": 1,
          "maximum": 4,
          "description": "Scale factor for PNG/SVG export of the visualization."
        }
      }
    },
    "configurationDefaults": {
      "[sysml]": {
        "editor.semanticHighlighting.enabled": true,
        "editor.guides.indentation": false,
        "editor.guides.bracketPairs": false,
        "editor.bracketPairColorization.enabled": false,
        "breadcrumbs.enabled": true,
        "breadcrumbs.showModules": true,
        "breadcrumbs.showNamespaces": true
      },
      "[kerml]": {
        "editor.semanticHighlighting.enabled": true,
        "editor.guides.indentation": false,
        "editor.guides.bracketPairs": false,
        "editor.bracketPairColorization.enabled": false,
        "breadcrumbs.enabled": true,
        "breadcrumbs.showModules": true,
        "breadcrumbs.showNamespaces": true
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run stage:package-content && npm run build:webview-assets && npm run build:webview && npm run build:headless-renderer && npm run compile",
    "stage:package-content": "node scripts/stage-package-content.js",
    "build:webview-assets": "node scripts/copy-webview-assets.js",
    "build:webview": "node scripts/build-webview.js",
    "build:headless-renderer": "node scripts/build-headless-renderer.js",
    "build:extension": "node scripts/build-extension.js",
    "verify:package-layout": "npm run stage:package-content && node scripts/verify-package-layout.js",
    "extract-styles": "node scripts/extract-styles.js",
    "compile": "npm run typecheck && tsc -p ./ && npm run build:extension",
    "test:lm-cli-unit": "tsc -p ./ && node --test out/test/suite/spec42Cli.test.js",
    "typecheck": "tsc -p ./ --noEmit && tsc -p ./tsconfig.webview.json --noEmit",
    "watch": "tsc -watch -p ./",
    "test": "vscode-test",
    "test:ux-unit": "vscode-test --config .vscode-test.ux-unit.mjs",
    "test:library-unit": "node ./node_modules/mocha/bin/mocha out/test/suite/libraryStatusViewModel.test.js",
    "test:state-view": "vscode-test --config .vscode-test.state-view.mjs",
    "test:interconnection": "vscode-test --config .vscode-test.interconnection.mjs",
    "test:interconnection-drone": "npm run test:interconnection",
    "test:multi-file": "vscode-test --config .vscode-test.multi-file.mjs",
    "test:workspace-smoke": "vscode-test --config .vscode-test.workspace-smoke.mjs",
    "test:server-restart": "vscode-test --config .vscode-test.server-restart.mjs",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/d3": "^7.4.3",
    "@types/mocha": "^10.0.0",
    "@types/node": "^22.0.0",
    "@types/vscode": "^1.99.0",
    "@vscode/codicons": "0.0.44",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.4.1",
    "@vscode/vsce": "^3.2.2",
    "esbuild": "^0.24.0",
    "typescript": "~5.6.0"
  },
  "dependencies": {
    "adm-zip": "^0.5.16",
    "d3": "^7.9.0",
    "elkjs": "^0.11.1",
    "vscode-languageclient": "^9.0.0",
    "vscode-languageserver-protocol": "^3.17.0"
  }
}
