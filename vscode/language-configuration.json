{
  "comments": {
    "lineComment": "//",
    "blockComment": ["/*", "*/"]
  },
  "brackets": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"]
  ],
  "autoClosingPairs": [
    { "open": "{", "close": "}" },
    { "open": "[", "close": "]" },
    { "open": "(", "close": ")" },
    { "open": "\"", "close": "\"" },
    { "open": "'", "close": "'" }
  ],
  "indentationRules": {
    "increaseIndentPattern": "^\\s*.*\\{\\s*$",
    "decreaseIndentPattern": "^\\s*\\}"
  },
  "folding": {
    "markers": {
      "start": "^\\s*(abstract\\s+)?(action|analysis|attribute|calc|case|comment|concern|connection|constraint|enumeration|event|feature|interface|item|metadata|namespace|objective|package|part|port|rendering|requirement|stakeholder|state|subject|transition|use|verification|view|viewpoint)(\\s+def)?\\b[^\\n]*\\{\\s*$",
      "end": "^\\s*\\}\\s*$"
    }
  },
  "onEnterRules": [
    {
      "beforeText": "^\\s*.*\\{\\s*$",
      "afterText": "^\\s*\\}\\s*$",
      "action": {
        "indentAction": "IndentOutdent"
      }
    },
    {
      "beforeText": "^\\s*.*\\{\\s*$",
      "action": {
        "indentAction": "Indent"
      }
    }
  ]
}
