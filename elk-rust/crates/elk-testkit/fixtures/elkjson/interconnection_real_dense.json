{
  "id": "root",
  "layoutOptions": {
    "elk.algorithm": "org.eclipse.elk.layered",
    "elk.direction": "RIGHT",
    "elk.edgeRouting": "ORTHOGONAL",
    "elk.layered.routingBackend": "libavoid",
    "elk.spacing.nodeNode": 34,
    "elk.spacing.nodeNodeBetweenLayers": 66
  },
  "children": [
    {
      "id": "left",
      "width": 220,
      "height": 180,
      "children": [
        { "id": "l1", "width": 80, "height": 50 },
        { "id": "l2", "width": 80, "height": 50 }
      ]
    },
    {
      "id": "mid",
      "width": 180,
      "height": 120
    },
    {
      "id": "right",
      "width": 220,
      "height": 180,
      "children": [
        { "id": "r1", "width": 80, "height": 50 },
        { "id": "r2", "width": 80, "height": 50 }
      ]
    }
  ],
  "edges": [
    { "id": "e1", "sources": ["l1"], "targets": ["mid"] },
    { "id": "e2", "sources": ["l2"], "targets": ["mid"] },
    { "id": "e3", "sources": ["left"], "targets": ["mid"], "layoutOptions": { "elk.edge.bundle": 1 } },
    { "id": "e4", "sources": ["left"], "targets": ["mid"], "layoutOptions": { "elk.edge.bundle": 2 } },
    { "id": "e5", "sources": ["left"], "targets": ["mid"], "layoutOptions": { "elk.edge.bundle": 3 } },
    { "id": "e6", "sources": ["mid"], "targets": ["right"], "layoutOptions": { "elk.edge.bundle": 1 } },
    { "id": "e7", "sources": ["mid"], "targets": ["right"], "layoutOptions": { "elk.edge.bundle": 2 } },
    { "id": "e8", "sources": ["mid"], "targets": ["right"], "layoutOptions": { "elk.edge.bundle": 3 } },
    { "id": "e9", "sources": ["mid"], "targets": ["r1"] },
    { "id": "e10", "sources": ["mid"], "targets": ["r2"] }
  ]
}
